{
  "name": "agrofount-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "seed:careers": "node dist/seed/careers.seed.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/database/data-source.ts src/config/database/migrations/Migration",
    "migration:check": "typeorm-ts-node-commonjs migration:generate --check -d src/config/database/data-source.ts src/config/database/migrations/_check",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/database/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/config/database/data-source.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.864.0",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/lib-storage": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@keyv/redis": "^5.1.6",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.26",
    "@types/pdf-parse": "^1.1.5",
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.1",
    "cacheable": "^1.10.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "nestjs-paginate": "^11.1.1",
    "otplib": "^12.0.1",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.4",
    "pg": "^8.21.0",
    "promise-retry": "^2.0.1",
    "sharp": "^0.35.2",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.27",
    "typeorm-extension": "^3.9.0"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.864.0",
    "@aws-sdk/client-lex-runtime-v2": "^3.864.0",
    "@aws-sdk/util-dynamodb": "^3.864.0",
    "@langchain/aws": "^0.1.14",
    "@langchain/community": "^0.3.53",
    "@langchain/core": "^0.3.72",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.4.2",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^2.0.12",
    "@types/xlsx": "^0.0.35",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "langchain": "^0.3.31",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "setupFiles": [
      "<rootDir>/polyfills/node-buffer.ts"
    ]
  },
  "overrides": {
    "multer": "^2.2.0",
    "ws": "^8.21.0",
    "fast-xml-parser": ">=5.7.0"
  }
}
