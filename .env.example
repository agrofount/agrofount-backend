NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=replace-me
DB_NAME=agrofount
DB_SCHEMA=public
# TypeORM creates and updates the schema from entity metadata at startup.
# Keep this false in production unless you explicitly accept automatic DDL.
DB_SYNCHRONIZE=true
DB_LOGGING=false
# Set both DB_SSL and DB_SSL_REJECT_UNAUTHORIZED to true in production.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRATION=15m
JWT_ISSUER=agrofount-api
JWT_AUDIENCE=agrofount-client
REFRESH_TOKEN_TTL_DAYS=30
MFA_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000
ENABLE_SWAGGER=true

FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001
REGISTRATION_PROMOTION=false
REGISTRATION_PROMOTION_AMOUNT=0

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_URL=https://api.paystack.co

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SEND_IN_BLUE_API_KEY=
SEND_IN_BLUE_FROM_EMAIL=
CONTACT_SUPPORT_EMAIL=
SELLER_INTEREST_ADMIN_EMAIL=dayo.akinbami@agrofount.com
CAREERS_RECRUITMENT_EMAIL=dayo.akinbami@agrofount.com

TERMII_API_KEY=
TERMII_SENDER_ID=
TERMII_BASE_URL=https://api.ng.termii.com/api
AFRICA_TALKING_API_KEY=
AFRICA_TALKING_USERNAME=
AFRICA_TALKING_SENDER_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_REGION=
AWS_BUCKET_NAME=
# Optional: set to your CloudFront distribution URL (e.g. https://cdn.agrofount.com) to use CDN URLs.
# If unset, falls back to direct S3 URLs (https://<bucket>.s3.<region>.amazonaws.com/...).
CLOUDFRONT_URL=
# Prefer an IAM task/instance role. Do not set static AWS keys in production.
DYNAMODB_TABLE_NAME=
IS_DYNAMO_LOCAL=false
LEX_BOT_ID=
LEX_BOT_ALIAS_ID=
LEX_LOCALE_ID=en_US
KENDRA_KNOWLEDGE_INDEX_ID=
AI_PROVIDER=bedrock
# AWS Bedrock model ID. Defaults to amazon.nova-lite-v1:0 if not set.
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
# Override the AWS region used specifically for Bedrock (falls back to AWS_REGION).
AWS_BEDROCK_REGION=
AI_FARM_ASSISTANT_ENABLED=true
